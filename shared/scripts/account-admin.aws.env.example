# Account-Admin credentials for AWS integration-test environment provisioning.
# Used by:  python scripts/provision_test_env.py provision
#
# SECURITY: This file contains secrets.  It is gitignored.  Never commit it.
#
# Copy and fill in:
#   cp scripts/account-admin.aws.env.example scripts/account-admin.aws.env
# Or run `make setup` from the aws/ directory — it copies this file automatically.
#
# ═════════════════════════════════════════════════════════════════════════════
# SECTION 1 — Databricks credentials (REQUIRED)
# ═════════════════════════════════════════════════════════════════════════════
#
# DATABRICKS_ACCOUNT_ID
#   Your Databricks account UUID.  The Service Principal must have
#   the Databricks Account Admin role.
#   https://accounts.cloud.databricks.com  > top-right menu > "Account ID"
#
# DATABRICKS_CLIENT_ID / DATABRICKS_CLIENT_SECRET
#   Account Console > User Management > Service Principals > <your SP>
#   > "Application ID"  →  CLIENT_ID
#   > "OAuth Secrets"  > Generate Secret  →  CLIENT_SECRET

DATABRICKS_ACCOUNT_ID       =
DATABRICKS_CLIENT_ID        =
DATABRICKS_CLIENT_SECRET    =

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 2 — AWS settings
# ═════════════════════════════════════════════════════════════════════════════
#
# DATABRICKS_AWS_REGION
#   AWS region for the new test workspace and metastore.
#
# AWS credentials (for automated S3 + IAM role management)
#   The provision script auto-creates an S3 bucket (genie-uc-test-<aws-account-id>)
#   and an IAM role per test run, and deletes them on teardown.
#
#   Required S3 permissions:
#     s3:CreateBucket, s3:DeleteBucket, s3:PutPublicAccessBlock,
#     s3:ListBucketVersions, s3:DeleteObject, s3:DeleteObjectVersion
#
#   Required IAM permissions:
#     iam:CreateRole, iam:DeleteRole, iam:PutRolePolicy, iam:DeleteRolePolicy,
#     iam:ListRolePolicies, iam:ListAttachedRolePolicies, iam:DetachRolePolicy,
#     iam:UpdateAssumeRolePolicy, sts:GetCallerIdentity
#
#   Choose ONE of these options:
#
#   Option A — explicit IAM user keys (recommended for CI):
#     Fill in AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY below.
#
#   Option B — AWS named profile:
#     Uncomment AWS_PROFILE below, leave the key fields blank.
#
#   Option C — environment variables:
#     export AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY before running.
#
#   Option D — instance role / ECS task role / SSO:
#     Leave all fields blank; boto3 picks up credentials automatically.
#
#   ⚠  Use LONG-LIVED credentials (AKIA* keys, not STS tokens).
#      The full pipeline (provision + ~90 min tests + teardown) can outlast
#      short-lived tokens.  If you must use STS, request ≥ 4 hours and
#      re-run teardown with fresh tokens on "ExpiredToken" errors.

DATABRICKS_AWS_REGION       = ap-southeast-2
AWS_ACCESS_KEY_ID           =
AWS_SECRET_ACCESS_KEY       =
AWS_SESSION_TOKEN           =
# AWS_PROFILE               = my-admin-profile
