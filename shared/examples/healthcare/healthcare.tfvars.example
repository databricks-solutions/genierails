# Healthcare ABAC — Example abac.auto.tfvars (ABAC config only)
# Generated by the AI-Assisted workflow (Tier 3) from ABAC_PROMPT.md
#
# Credentials go in auth.auto.tfvars; environment config in env.auto.tfvars.
#
# Usage:
#   1. cp auth.auto.tfvars.example auth.auto.tfvars   (credentials — gitignored)
#      cp env.auto.tfvars.example env.auto.tfvars     (tables + environment)
#   2. cp examples/healthcare/healthcare.tfvars.example abac.auto.tfvars
#   3. Run examples/healthcare/masking_functions.sql in a Databricks SQL editor
#   4. terraform init && terraform plan && terraform apply

# === Groups ===
groups = {
  "Nurse"                 = { description = "Bedside care — partial PII, limited clinical notes" }
  "Physician"             = { description = "Full clinical access, full PII for their region" }
  "Billing_Clerk"         = { description = "Financial records — masked PHI, no clinical notes" }
  "Chief_Medical_Officer" = { description = "Full unrestricted access across all regions" }
  "US_East_Staff"         = { description = "Row access limited to US_EAST facility data" }
  "US_West_Staff"         = { description = "Row access limited to US_WEST facility data" }
}

# === Tag Policies ===
tag_policies = [
  { key = "phi_level",        description = "Protected Health Information access tier", values = ["Restricted_PHI", "Limited_PHI", "Full_PHI"] },
  { key = "pii_level",        description = "Personally identifiable information tier",  values = ["Limited_PII", "Full_PII"] },
  { key = "financial_access", description = "Billing/financial data clearance",          values = ["Summary", "Full"] },
  { key = "facility_region",  description = "Hospital facility region for row filtering", values = ["Regional"] },
]

# === Tag Assignments ===
# entity_name must be fully qualified:
#   Tables:  "catalog.schema.TableName"
#   Columns: "catalog.schema.TableName.ColumnName"
tag_assignments = [
  # --- Patients table ---
  { entity_type = "tables",  entity_name = "hc_catalog.clinical.Patients",                tag_key = "pii_level",       tag_value = "Full_PII" },
  { entity_type = "tables",  entity_name = "hc_catalog.clinical.Patients",                tag_key = "facility_region", tag_value = "Regional" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.MRN",            tag_key = "phi_level",       tag_value = "Restricted_PHI" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.FirstName",      tag_key = "pii_level",       tag_value = "Limited_PII" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.LastName",       tag_key = "pii_level",       tag_value = "Limited_PII" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.SSN",            tag_key = "pii_level",       tag_value = "Full_PII" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.Email",          tag_key = "pii_level",       tag_value = "Limited_PII" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.Phone",          tag_key = "pii_level",       tag_value = "Limited_PII" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.Address",        tag_key = "pii_level",       tag_value = "Limited_PII" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Patients.InsuranceID",    tag_key = "phi_level",       tag_value = "Limited_PHI" },

  # --- Encounters table ---
  { entity_type = "tables",  entity_name = "hc_catalog.clinical.Encounters",                  tag_key = "phi_level",       tag_value = "Full_PHI" },
  { entity_type = "tables",  entity_name = "hc_catalog.clinical.Encounters",                  tag_key = "facility_region", tag_value = "Regional" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Encounters.DiagnosisCode",    tag_key = "phi_level",       tag_value = "Restricted_PHI" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Encounters.DiagnosisDesc",    tag_key = "phi_level",       tag_value = "Full_PHI" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Encounters.TreatmentNotes",   tag_key = "phi_level",       tag_value = "Full_PHI" },

  # --- Prescriptions table — column-level PHI tags only ---
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Prescriptions.DrugName",      tag_key = "phi_level",       tag_value = "Limited_PHI" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Prescriptions.Dosage",        tag_key = "phi_level",       tag_value = "Limited_PHI" },

  # --- Billing table — column-level financial tags only ---
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Billing.TotalAmount",         tag_key = "financial_access", tag_value = "Full" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Billing.InsurancePaid",       tag_key = "financial_access", tag_value = "Summary" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Billing.PatientOwed",         tag_key = "financial_access", tag_value = "Summary" },
  { entity_type = "columns", entity_name = "hc_catalog.clinical.Billing.InsuranceID",         tag_key = "phi_level",        tag_value = "Limited_PHI" },
]

# === FGAC Policies ===
# catalog, function_catalog, function_schema are REQUIRED on each policy.
# function_name is relative — Terraform prepends catalog.schema automatically.
fgac_policies = [
  # -- PII masking for Nurses --
  {
    name             = "pii_nurse_partial"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Nurse"]
    comment          = "Nurses see partial names and contact info"
    match_condition  = "hasTagValue('pii_level', 'Limited_PII')"
    match_alias      = "pii_limited"
    function_name    = "mask_pii_partial"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },
  {
    name             = "pii_nurse_full_redact"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Nurse"]
    comment          = "Nurses cannot see SSN"
    match_condition  = "hasTagValue('pii_level', 'Full_PII')"
    match_alias      = "pii_full"
    function_name    = "mask_ssn"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },

  # -- PII masking for Billing Clerks --
  {
    name             = "pii_billing_partial"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Billing_Clerk"]
    comment          = "Billing clerks see partial patient names"
    match_condition  = "hasTagValue('pii_level', 'Limited_PII')"
    match_alias      = "pii_limited"
    function_name    = "mask_pii_partial"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },
  {
    name             = "pii_billing_ssn"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Billing_Clerk"]
    comment          = "Billing clerks cannot see SSN"
    match_condition  = "hasTagValue('pii_level', 'Full_PII')"
    match_alias      = "pii_full"
    function_name    = "mask_redact"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },

  # -- PHI masking for Nurses --
  {
    name             = "phi_nurse_mrn"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Nurse"]
    comment          = "Nurses see last-4 of MRN"
    match_condition  = "hasTagValue('phi_level', 'Restricted_PHI')"
    match_alias      = "phi_restricted"
    function_name    = "mask_mrn"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },

  # -- PHI masking for Billing Clerks (no clinical details) --
  {
    name             = "phi_billing_redact"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Billing_Clerk"]
    comment          = "Billing clerks cannot see diagnosis or treatment notes"
    match_condition  = "hasTagValue('phi_level', 'Full_PHI')"
    match_alias      = "phi_full"
    function_name    = "mask_redact"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },
  {
    name             = "phi_billing_diagnosis"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Billing_Clerk"]
    comment          = "Billing clerks see ICD category only"
    match_condition  = "hasTagValue('phi_level', 'Restricted_PHI')"
    match_alias      = "phi_restricted"
    function_name    = "mask_diagnosis_code"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },

  # -- Financial masking for Nurses --
  {
    name             = "fin_nurse_rounded"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Nurse"]
    comment          = "Nurses see rounded billing amounts"
    match_condition  = "hasTagValue('financial_access', 'Full')"
    match_alias      = "fin_full"
    function_name    = "mask_amount_rounded"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },
  {
    name             = "fin_nurse_summary"
    policy_type      = "POLICY_TYPE_COLUMN_MASK"
    catalog          = "hc_catalog"
    to_principals    = ["Nurse"]
    comment          = "Nurses cannot see insurance payment details"
    match_condition  = "hasTagValue('financial_access', 'Summary')"
    match_alias      = "fin_summary"
    function_name    = "mask_redact"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },

  # -- Insurance ID masking (tokenize for non-billing staff) --
  {
    name              = "phi_insurance_mask"
    policy_type       = "POLICY_TYPE_COLUMN_MASK"
    catalog           = "hc_catalog"
    to_principals     = ["account users"]
    except_principals = ["Billing_Clerk", "Chief_Medical_Officer"]
    comment           = "Insurance ID tokenized for non-billing staff"
    match_condition   = "hasTagValue('phi_level', 'Limited_PHI')"
    match_alias       = "phi_limited"
    function_name     = "mask_account_number"
    function_catalog  = "hc_catalog"
    function_schema   = "clinical"
  },

  # -- Regional row filters --
  {
    name             = "region_us_east"
    policy_type      = "POLICY_TYPE_ROW_FILTER"
    catalog          = "hc_catalog"
    to_principals    = ["US_East_Staff"]
    comment          = "US East staff see only US_EAST facility data"
    when_condition   = "hasTagValue('facility_region', 'Regional')"
    function_name    = "filter_facility_us_east"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },
  {
    name             = "region_us_west"
    policy_type      = "POLICY_TYPE_ROW_FILTER"
    catalog          = "hc_catalog"
    to_principals    = ["US_West_Staff"]
    comment          = "US West staff see only US_WEST facility data"
    when_condition   = "hasTagValue('facility_region', 'Regional')"
    function_name    = "filter_facility_us_west"
    function_catalog = "hc_catalog"
    function_schema  = "clinical"
  },
]

# === Group Members (optional — fill in account-level user IDs) ===
group_members = {}
