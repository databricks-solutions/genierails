# Environment Config — Genie Space settings, warehouse, and tables.
# Make loads this file into the correct Terraform root for you.
# This file is safe to check into Git (no secrets).
#
#   cp env.auto.tfvars.example env.auto.tfvars

# ─── Genie Spaces ───────────────────────────────────────────────────────────
#
# Define one or more Genie Spaces for this environment. Each entry must have a
# stable `key` that links to the matching entry in abac.auto.tfvars under
# `genie_space_configs`. All table names must be fully qualified:
# catalog.schema.table  (or catalog.schema.* to include all tables in a schema).
#
# name             - human-readable title shown in the Genie UI.
#                    Also used to look up genie_space_configs (keys must match exactly).
#                    Renaming a space destroys and re-creates it in Terraform.
# genie_space_id   - leave empty → tool creates and fully manages the space (default).
#                    set to an existing ID → tool attaches to it and manages config + ACLs.
# sql_warehouse_id - (optional) per-space warehouse override. When omitted or empty, the
#                    space uses the top-level sql_warehouse_id below. See warehouse config.
# uc_tables        - fully-qualified table references (catalog.schema.table or catalog.schema.*).
#
# ── Mode 1: auto-create and fully manage a new space ───────────────────────
#   genie_spaces = [
#     {
#       name             = "Sales Analytics"
#       genie_space_id   = ""            # empty → tool creates the space and manages its lifecycle
#       sql_warehouse_id = ""            # optional; empty uses the shared warehouse
#       uc_tables = [
#         "dev_catalog.sales.orders",
#         "dev_catalog.sales.customers",
#         "dev_catalog.finance.*",
#       ]
#     },
#   ]
#
# ── Mode 2: attach to an existing space (auto-discover tables from the API) ─
#   Only genie_space_id is required. name and uc_tables are both optional.
#   make generate queries the Genie Space API to discover what tables the space
#   uses, then generates full ABAC config, masking, and group permissions from
#   those tables. Terraform only applies group ACLs — space content is never
#   modified and the space is never deleted by make destroy.
#
#   genie_spaces = [
#     {
#       genie_space_id = "01ef7b3c2a4d5e6f"   # only field required; find in the Genie Space URL
#       # name omitted     → Terraform key defaults to genie_space_id
#       # uc_tables omitted → make generate fetches them from the Genie API
#     },
#   ]
#
#   After running make generate, copy the printed discovered tables into
#   data_access/env.auto.tfvars so that UC grants and masking are also applied.
#
# ── Multi-space: mix of auto-created and pre-existing spaces ───────────────
#   genie_spaces = [
#     {
#       name           = "Executive Dashboard"
#       genie_space_id = "01ef7b3c2a4d5e6f"    # pre-existing — ACLs only
#     },
#     {
#       name      = "Ops Analytics"             # no ID → tool creates and fully manages
#       uc_tables = ["dev_catalog.ops.incidents", "dev_catalog.ops.sla_metrics"]
#     },
#   ]
#
# ── Single space spanning multiple catalogs ────────────────────────────────
#   genie_spaces = [
#     {
#       name      = "Cross-Domain Analytics"
#       uc_tables = [
#         "finance_catalog.finance.transactions",   # catalog 1
#         "hr_catalog.hr.employees",                # catalog 2
#       ]
#     },
#   ]
#
genie_spaces = []

# ─── SQL Warehouse ───────────────────────────────────────────────────────────
#
# sql_warehouse_id is a two-level config:
#
#   Top-level (here):   shared fallback warehouse used by all spaces that do not
#                       specify their own. Leave empty to auto-create a serverless
#                       warehouse that all spaces share.
#
#   Per-space (inside genie_spaces[*]):   overrides the top-level warehouse for
#                       that specific space only. Useful when different teams use
#                       different warehouses, or when a space needs a larger size.
#
# Example — all spaces share one warehouse (most common):
#   sql_warehouse_id = ""          # auto-create serverless
#
# Example — bring your own shared warehouse:
#   sql_warehouse_id = "abc123ef"  # Databricks workspace > SQL Warehouses > copy ID
#
# Example — per-space warehouse override:
#   genie_spaces = [
#     { name = "Finance", sql_warehouse_id = "abc123ef", uc_tables = [...] },
#     { name = "HR",      sql_warehouse_id = "def456gh", uc_tables = [...] },
#   ]
#   sql_warehouse_id = ""   # top-level fallback (unused here since both spaces override)
#
sql_warehouse_id = ""

# ─── Genie-Only Mode (Least Privilege) ─────────────────────────────────────
#
# Set genie_only = true when the service principal only has Workspace Admin
# (no Account Admin, no Metastore Admin). This is the recommended mode for
# BU teams in a self-service Genie deployment where a central governance team
# manages groups and ABAC separately.
#
# When genie_only = true:
#   - Account-level operations are skipped (group lookup, workspace assignment,
#     entitlements) — the governance team manages these via make apply-governance
#   - databricks_account_id can be omitted or left empty in auth.auto.tfvars
#   - groups must be {} (empty) in abac.auto.tfvars
#   - Genie Space ACLs are skipped (governance team manages group permissions)
#   - Warehouse auto-create still works (Workspace Admin can create warehouses)
#
# Usage:
#   make generate MODE=genie ENV=<bu-env>
#   make apply-genie ENV=<bu-env>
#
genie_only = false

# ─── Country / Region Awareness ─────────────────────────────────────────────
#
# Set country to inject country-specific identifier knowledge into the AI
# prompt during `make generate`. This teaches the AI about local identifiers
# (e.g. Australian TFN, Indian Aadhaar, Singapore NRIC) and provides
# country-specific masking functions alongside the default US/global patterns.
#
# Value: comma-separated region codes, or empty for US/global defaults.
#
# Available regions: ANZ (Australia & New Zealand), IN (India), SEA (Singapore & Malaysia)
# More at: shared/countries/
#
# Examples:
#   country = ""         # US/global defaults (current behavior)
#   country = "ANZ"      # Australia & NZ identifiers (TFN, Medicare, BSB, IRD, NHI)
#   country = "IN"       # India identifiers (Aadhaar, PAN, GSTIN)
#   country = "SEA"      # Singapore & Malaysia (NRIC, FIN, MyKad)
#   country = "ANZ,SEA"  # Multi-region dataset
#
country = ""

# ─── Multi-Environment Layout ───
#
# For multi-env deployments on the same Databricks account, the quickstart
# keeps one shared account state plus one env-scoped data_access + workspace
# state per environment:
#
#   envs/
#     account/                    # shared state — account module only
#       auth.auto.tfvars          # defaults to workspace auth symlink; replace if needed
#       env.auto.tfvars           # account-specific settings
#       abac.auto.tfvars          # groups + optional group_members only
#
#     dev/                        # dev workspace module state
#       auth.auto.tfvars          # workspace SP credentials
#       env.auto.tfvars           # this file: genie_spaces with dev catalog table refs
#       data_access/
#         auth.auto.tfvars        # defaults to ../auth.auto.tfvars; replace if needed
#         env.auto.tfvars         # uc_catalog + uc_tables for FGAC/masking scope
#         abac.auto.tfvars        # env-scoped governance config
#         masking_functions.sql   # env-scoped masking SQL
#       abac.auto.tfvars          # groups lookup + genie_space_configs only
#
#     prod/                       # prod workspace module state
#       auth.auto.tfvars
#       env.auto.tfvars           # genie_spaces with prod catalog refs (written by make promote)
#       data_access/
#         auth.auto.tfvars
#         env.auto.tfvars
#         abac.auto.tfvars
#         masking_functions.sql
#       abac.auto.tfvars          # groups lookup + genie_space_configs only
#
# Account layer: groups + optional group_members.
# Data-access layer: env-scoped governance + masking SQL.
# Workspace layers: groups looked up by name, workspace assignments/
# entitlements, warehouse, and Genie Space lifecycle.
# `make destroy` only tears down the selected layer state.
#
# ─── Promotion ───
#
# To promote dev → prod, provide a full catalog name mapping:
#
#   make promote SOURCE_ENV=dev DEST_ENV=prod \
#     DEST_CATALOG_MAP="dev_catalog=prod_catalog"
#
# For multiple catalogs across spaces:
#
#   make promote SOURCE_ENV=dev DEST_ENV=prod \
#     DEST_CATALOG_MAP="dev_catalog_a=prod_catalog_a,dev_catalog_b=prod_catalog_b"
#
# The promote command auto-detects source catalogs from uc_tables and will
# fail with a helpful error if DEST_CATALOG_MAP is missing or incomplete.
