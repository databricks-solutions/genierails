# OS
.DS_Store

# IDE
.idea/

# Python
__pycache__/
*.pyc

# Environment / secrets
.env
*conf*.json

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.backup
.terraform/

# AI-generated output (user-specific)
generated/
masking_functions.sql

# User-created environment directories
envs/

# Local import IDs
import_ids.env

# User-specific credentials (only track the .example)
auth.auto.tfvars

# Auto-created Genie Space ID (managed by Terraform lifecycle)
.genie_space_id

# Parallel test runner logs
shared/scripts/logs/

# Claude Code: ignore personal overrides and runtime files only — everything else
# under .claude/ (skills/, commands/, hooks/, agents/, shared settings.json) is
# shareable project config and should be committed.
.claude/settings.local.json
.claude/scheduled_tasks.lock
