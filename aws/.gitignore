# Local import IDs (copy from import_ids.env.example)
import_ids.env

# User-created environment directories (create from *.example files in shared/)
envs/

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.backup
.terraform/

# User-specific credentials (only track the .example)
auth.auto.tfvars

# AI-generated output (user-specific)
generated/
masking_functions.sql

# Auto-created Genie Space ID (managed by Terraform lifecycle)
.genie_space_id

# Python cache
__pycache__/
*.pyc
